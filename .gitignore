```gitignore
# ==========================
# Python
# ==========================
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/

# ==========================
# IDEs
# ==========================
.vscode/
.idea/

# ==========================
# Temporary files
# ==========================
temp/
tmp/
*.tmp
tempCodeRunnerFile.py

# ==========================
# Logs
# ==========================
*.log

# ==========================
# Operating System
# ==========================
.DS_Store
Thumbs.db

# ==========================
# OneDrive temporary files
# ==========================
~$*

# ==========================
# Raw sequencing data
# ==========================
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.bam
*.sam

# ==========================
# Large databases
# ==========================
kraken_db/
kraken2_db/
VFDB/
MetaCyc/
HUMAnN_databases/
bowtie2_indexes/

# ==========================
# QC Outputs
# ==========================
multiqc/
multiqc_report.html
fastqscreen_multiqc/

# ==========================
# Large analysis outputs
# ==========================
project outputs(oral-gut)/
results/temp/
lib/

# ==========================
# Compressed files
# ==========================
*.zip
*.tar
*.tar.gz
*.gz
*.7z

# ==========================
# Environment variables
# ==========================
.env
.env.*

# ==========================
# Python packaging
# ==========================
build/
dist/
*.egg-info/

# ==========================
# R
# ==========================
.Rhistory
.RData
.Rproj.user/
```
